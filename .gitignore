# Local-only artifacts must not be committed.
# ACP is a convention spec; the skill, templates, and specs are versioned.
# Internal planning documents stay on the maintainer's machine only.

# Internal design / planning notes
/plan.md
/internal/

# Editor and OS noise
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.idea/
.vscode/

# Node / tooling (defensive; the spec itself has no dependencies)
node_modules/
.pnpm-store/
package-lock.json
*.log

# Local secret / config (none expected, but defensive)
.env
.env.local

# ACP workspace root: ignore a project-root `.acp/` directory if one is
# ever created inside THIS repo (the ACP repo itself is a convention spec,
# not an ACP-using project). The starter templates under `templates/.acp/`
# remain tracked; this rule matches only the repo root.
/.acp/
